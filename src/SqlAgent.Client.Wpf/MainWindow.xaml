<Window x:Class="SqlAgent.Client.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SqlAgent.Client.Wpf.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="SQL Agent" Height="640" Width="980">
    <TabControl Margin="6">

        <!-- ===== Connections ===== -->
        <TabItem Header="Connections">
            <Grid DataContext="{Binding Connections}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0" Grid.Column="0" Margin="4"
                         ItemsSource="{Binding Databases}" SelectedItem="{Binding Selected}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                <TextBlock FontSize="11" Foreground="Gray">
                                    <Run Text="{Binding Provider, Mode=OneWay}" />
                                    <Run Text=" · " />
                                    <Run Text="{Binding IsReadOnly, Mode=OneWay, StringFormat='read-only={0}'}" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8">
                    <TextBlock Text="Name" />
                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8" />

                    <TextBlock Text="Provider" />
                    <ComboBox ItemsSource="{Binding Providers}" SelectedItem="{Binding EditProvider}" Margin="0,2,0,8" />

                    <CheckBox Content="Read-only (block writes)" IsChecked="{Binding EditIsReadOnly}" Margin="0,2,0,8" />

                    <TextBlock Text="Connection string" />
                    <TextBox Text="{Binding EditConnectionString, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,8" TextWrapping="Wrap" AcceptsReturn="True" MinLines="2" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="New" Command="{Binding NewCommand}" Width="70" Margin="0,0,6,0" />
                        <Button Content="Save" Command="{Binding SaveCommand}" Width="70" Margin="0,0,6,0" />
                        <Button Content="Delete" Command="{Binding DeleteCommand}" Width="70" Margin="0,0,6,0" />
                        <Button Content="Test" Command="{Binding TestCommand}" Width="70" Margin="0,0,6,0" />
                        <Button Content="Refresh" Command="{Binding RefreshCommand}" Width="70" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Margin="4" Foreground="DarkSlateGray"
                           Text="{Binding Status}" TextWrapping="Wrap" />
            </Grid>
        </TabItem>

        <!-- ===== Table visibility ===== -->
        <TabItem Header="Tables">
            <DockPanel DataContext="{Binding TableVisibility}" Margin="4">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Width="80" />
                    <TextBlock Text="{Binding Status}" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="DarkSlateGray" />
                </StackPanel>
                <ListView ItemsSource="{Binding Tables}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Visible" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsVisible}" HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Table" Width="400" DisplayMemberBinding="{Binding Display}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </TabItem>

        <!-- ===== Chat / query ===== -->
        <TabItem Header="Chat">
            <Grid DataContext="{Binding Chat}" Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Transcript -->
                <ListBox Grid.Row="0" ItemsSource="{Binding Messages}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="2" Padding="6" CornerRadius="4" Background="#F2F2F2">
                                <StackPanel>
                                    <TextBlock Text="{Binding Role}" FontSize="10" Foreground="Gray" />
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontFamily="Consolas">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                                        <Setter Property="Foreground" Value="DarkRed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Result grid -->
                <DataGrid Grid.Row="1" Margin="0,6,0,6" ItemsSource="{Binding Results}"
                          AutoGenerateColumns="True" IsReadOnly="True"
                          Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}" />

                <!-- Executed SQL + copy -->
                <DockPanel Grid.Row="2" Margin="0,0,0,4"
                           Visibility="{Binding HasSql, Converter={StaticResource BoolToVis}}">
                    <Button DockPanel.Dock="Right" Content="Copy SQL" Command="{Binding CopySqlCommand}" Width="80" />
                    <TextBlock Text="{Binding LastSql}" FontFamily="Consolas" Foreground="DarkSlateGray"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </DockPanel>

                <!-- Input -->
                <DockPanel Grid.Row="3">
                    <Button DockPanel.Dock="Right" Content="Send" Command="{Binding SendCommand}"
                            Width="80" Margin="6,0,0,0" />
                    <Button DockPanel.Dock="Right" Content="Voice" Command="{Binding VoiceCommand}" Width="80"
                            Visibility="{Binding IsVoiceSupported, Converter={StaticResource BoolToVis}}" />
                    <TextBox Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" MinLines="2" MaxLines="6" VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" />
                </DockPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
